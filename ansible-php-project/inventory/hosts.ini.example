# VPS: PHP + PostgreSQL/MySQL/Redis (см. Readme-vps.md)
# При запуске Ansible из WSL ключ можно брать из профиля Windows.

[vps]
203.0.113.10 ansible_user=deploy

[vps:vars]
ansible_port=22
ansible_ssh_private_key_file=/mnt/c/Users/username/.ssh/id_rsa_cloud
ansible_ssh_timeout=60
ansible_python_interpreter=/usr/bin/python3
