# Пример структуры (файл с реальными паролями не коммитить).
# Создайте vars/mysql_secrets.yml командой:
#   python3 scripts/generate_mysql_secrets.py
#
# Или скопируйте этот файл в mysql_secrets.yml и подставьте свои пароли.

mysql_site_passwords:
  "example.org": "strong_mysql_site_password"

mysql_all_db_user_password: "strong_mysql_all_db_password"
