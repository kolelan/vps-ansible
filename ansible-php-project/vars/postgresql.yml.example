---
# Глобальные настройки PostgreSQL для playbooks/deploy_postgresql.yml
# Пароли: vars/pgsql_secrets.yml (scripts/generate_pgsql_secrets.py). Сайты — vars/php_sites.yml (опционально pgsql_id).

postgresql:
  port: 5432
  # Только локальные подключения; сетевой доступ задаётся в pg_hba (см. allowed_networks).
  listen_addresses: "127.0.0.1"
  allowed_networks:
    - "127.0.0.1/32"
    - "::1/128"
  auth_method: "scram-sha-256"

postgresql_packages:
  - "postgresql"
  - "postgresql-contrib"
  - "python3-psycopg2"

# Кодировка и локали для новых БД сайтов (template0 — чистый шаблон).
postgresql_site_db_defaults:
  encoding: "UTF8"
  lc_collate: "C.UTF-8"
  lc_ctype: "C.UTF-8"
  template: "template0"

# Отдельный логин: полные права на все базы из php_sites (миграции, админка, бэкапы).
# Пароль: postgresql_all_db_user_password в vars/pgsql_secrets.yml
postgresql_all_databases_user:
  name: all_db_user
