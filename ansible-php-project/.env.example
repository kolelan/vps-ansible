# Шаблон переменных окружения. Скопируйте в .env и подставьте свои значения.
# Файл .env в репозиторий не попадает (.gitignore).

# Пароль SSH для пользователя root на VPS (см. group_vars/vps.yml → ansible_password).
# Нужен, если подключение идёт по паролю, а не по ключу.
# При входе только по ключу можно оставить пустым или не создавать .env.
VPS_SSH_PASSWORD=
